# ─────────────────────────────────────────────────────────────────────────────
# Kopieer dit bestand naar .env.local en vul de waarden in.
# .env.local staat in .gitignore — commit dit NOOIT naar git.
# ─────────────────────────────────────────────────────────────────────────────

# Neon PostgreSQL connection string
# Te vinden in het Neon dashboard: Project > Connection string
# Formaat: postgresql://[user]:[password]@[host]/[dbname]?sslmode=require
DATABASE_URL="postgresql://user:password@ep-xxxx.eu-west-2.aws.neon.tech/neondb?sslmode=require"

# Netlify Blob Storage — alleen nodig voor het seed script (seed-blob-images.ts).
# Te vinden in: Netlify dashboard → Site settings → General → Site ID
# Auth token: Netlify dashboard → User settings → Applications → Personal access tokens
NETLIFY_SITE_ID="your-netlify-site-id"
NETLIFY_AUTH_TOKEN="your-netlify-personal-access-token"
