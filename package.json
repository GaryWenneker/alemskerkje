{
  "name": "alemskerkje",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postbuild": "node -e \"require('fs').cpSync('.next/static', '.next/_next/static', {recursive: true})\"",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "seed": "node --env-file=.env.local --import tsx src/scripts/seed.ts",
    "seed:images": "node --env-file=.env.local --import tsx src/scripts/seed-blob-images.ts",
    "seed:kirsty": "node --env-file=.env.local --import tsx src/scripts/seed-kirsty-mcgee.ts",
    "import:agenda": "node --env-file=.env.local --import tsx src/scripts/import-agenda.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "@netlify/blobs": "^10.7.4",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.40.1",
    "jose": "^6.2.2",
    "next": "^15.2.3",
    "next-auth": "^5.0.0-beta.25",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "^5.15.9",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.20",
    "dotenv": "^16.6.1",
    "drizzle-kit": "^0.30.4",
    "eslint": "^9",
    "eslint-config-next": "^15.2.3",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
